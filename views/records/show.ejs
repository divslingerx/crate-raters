<div class="max-w-4xl mx-auto">
    <div class="bg-gray-900 border border-gray-800 rounded-lg overflow-hidden">
        <div class="md:flex">
            <% if (record.image) { %>
                <div class="md:w-1/2">
                    <img src="<%= record.image %>" alt="<%= record.album %>" class="w-full aspect-square object-cover">
                </div>
            <% } %>
            <div class="p-6 md:w-1/2 flex flex-col justify-between">
                <div>
                    <h1 class="text-3xl font-bold text-white mb-2"><%= record.album %></h1>
                    <p class="text-xl text-gray-300 mb-4"><%= record.artist %></p>
                    <% if (record.year) { %>
                        <p class="text-gray-400 mb-2"><span class="font-medium text-gray-300">Year:</span> <%= record.year %></p>
                    <% } %>
                    <% if (record.found) { %>
                        <p class="text-gray-400 mb-4"><span class="font-medium text-gray-300">Found:</span> <%= record.found %></p>
                    <% } %>
                </div>
                <% if (user && user.id === record.userId) { %>
                    <div class="flex gap-3 mt-4">
                        <a href="/records/<%= record.id %>/edit" class="bg-yellow-600 hover:bg-yellow-500 text-white px-4 py-2 rounded-lg font-medium transition-colors">Edit</a>
                        <button
                            hx-delete="/records/<%= record.id %>"
                            hx-confirm="Are you sure?"
                            hx-swap="none"
                            class="bg-red-600 hover:bg-red-500 text-white px-4 py-2 rounded-lg font-medium transition-colors"
                        >Delete</button>
                        <form action="/records/<%= record.id %>?_method=DELETE" method="POST" class="inline hidden" id="delete-fallback">
                            <button type="submit" class="bg-red-600 hover:bg-red-500 text-white px-4 py-2 rounded-lg font-medium transition-colors">Delete</button>
                        </form>
                    </div>
                <% } %>
            </div>
        </div>
    </div>

    <!-- Comments Section -->
    <div class="mt-8">
        <div class="flex items-center justify-between mb-4">
            <h2 class="text-2xl font-bold text-white">Comments</h2>
        </div>
        <% if (user) { %>
            <form
                hx-post="/records/<%= record.id %>/comments"
                hx-target="#comments-list"
                hx-swap="afterbegin"
                hx-on::after-request="if(event.detail.successful) this.reset()"
                action="/records/<%= record.id %>/comments"
                method="POST"
                class="mb-6"
            >
                <div class="flex gap-3">
                    <input type="text" name="text" placeholder="Add a comment..." required
                        class="flex-1 bg-gray-800 border border-gray-700 rounded-lg px-4 py-2 text-gray-100 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent">
                    <button type="submit" class="bg-indigo-600 hover:bg-indigo-500 text-white px-4 py-2 rounded-lg font-medium transition-colors text-sm">Add Comment</button>
                </div>
            </form>
        <% } %>
        <div id="comments-list" class="space-y-4">
            <% if (record.comments && record.comments.length > 0) { %>
                <% record.comments.forEach(function(comment) { %>
                    <%- include('../partials/comment', { comment, recordId: record.id, user }) %>
                <% }); %>
            <% } %>
        </div>
        <% if (!record.comments || record.comments.length === 0) { %>
            <p class="text-gray-500 no-comments">No comments yet.</p>
        <% } %>
    </div>

    <div class="mt-6">
        <a href="/records" class="text-indigo-400 hover:text-indigo-300">Back to Records</a>
    </div>
</div>
