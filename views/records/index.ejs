<div class="flex justify-between items-center mb-8">
    <h1 class="text-3xl font-bold">All Records</h1>
    <% if (user) { %>
        <a href="/records/new" class="bg-indigo-600 hover:bg-indigo-500 text-white px-4 py-2 rounded-lg font-medium transition-colors">+ Add Record</a>
    <% } %>
</div>

<div class="mb-6">
    <input
        type="text"
        name="q"
        placeholder="Search by artist or album..."
        hx-get="/records"
        hx-trigger="input changed delay:300ms"
        hx-target="#records-grid"
        hx-swap="innerHTML"
        class="w-full bg-gray-800 border border-gray-700 rounded-lg px-4 py-2 text-gray-100 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent"
    >
</div>

<div id="records-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
    <% records.forEach(function(record) { %>
        <%- include('../partials/record-card', { record }) %>
    <% }); %>
</div>
