<div class="max-w-md mx-auto">
    <h1 class="text-3xl font-bold mb-8 text-center">Edit Record</h1>
    <form action="/records/<%= record.id %>?_method=PUT" method="POST" class="space-y-4">
        <div>
            <label for="artist" class="block text-sm font-medium text-gray-300 mb-1">Artist</label>
            <input type="text" id="artist" name="artist" required
                value="<%= record.artist %>"
                class="w-full px-4 py-2 bg-gray-800 border border-gray-700 rounded-lg text-white focus:outline-none focus:ring-2 focus:ring-indigo-500">
        </div>
        <div>
            <label for="album" class="block text-sm font-medium text-gray-300 mb-1">Album</label>
            <input type="text" id="album" name="album" required
                value="<%= record.album %>"
                class="w-full px-4 py-2 bg-gray-800 border border-gray-700 rounded-lg text-white focus:outline-none focus:ring-2 focus:ring-indigo-500">
        </div>
        <div>
            <label for="image" class="block text-sm font-medium text-gray-300 mb-1">Image URL</label>
            <input type="url" id="image" name="image"
                value="<%= record.image || '' %>"
                class="w-full px-4 py-2 bg-gray-800 border border-gray-700 rounded-lg text-white focus:outline-none focus:ring-2 focus:ring-indigo-500">
        </div>
        <div>
            <label for="year" class="block text-sm font-medium text-gray-300 mb-1">Year</label>
            <input type="text" id="year" name="year"
                value="<%= record.year || '' %>"
                class="w-full px-4 py-2 bg-gray-800 border border-gray-700 rounded-lg text-white focus:outline-none focus:ring-2 focus:ring-indigo-500">
        </div>
        <div>
            <label for="found" class="block text-sm font-medium text-gray-300 mb-1">Where Found</label>
            <input type="text" id="found" name="found"
                value="<%= record.found || '' %>"
                class="w-full px-4 py-2 bg-gray-800 border border-gray-700 rounded-lg text-white focus:outline-none focus:ring-2 focus:ring-indigo-500">
        </div>
        <button type="submit" class="w-full bg-indigo-600 hover:bg-indigo-500 text-white py-2 rounded-lg font-medium transition-colors">
            Update Record
        </button>
    </form>
    <p class="text-center text-gray-400 mt-4"><a href="/records/<%= record.id %>" class="text-indigo-400 hover:text-indigo-300">Cancel</a></p>
</div>
