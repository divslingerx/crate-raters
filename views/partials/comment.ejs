<div class="comment bg-gray-900 border border-gray-800 rounded-lg p-4">
    <p class="text-gray-300 mb-2"><%= comment.text %></p>
    <div class="flex items-center justify-between">
        <p class="text-sm text-gray-500">by <%= comment.author ? comment.author.name : 'Unknown' %></p>
        <% if (user && user.id === comment.userId) { %>
            <div class="flex gap-2">
                <a href="/records/<%= recordId %>/comments/<%= comment.id %>/edit" class="text-yellow-500 hover:text-yellow-400 text-sm font-medium">Edit</a>
                <button
                    hx-delete="/records/<%= recordId %>/comments/<%= comment.id %>"
                    hx-target="closest .comment"
                    hx-swap="outerHTML"
                    hx-confirm="Are you sure?"
                    class="text-red-500 hover:text-red-400 text-sm font-medium"
                >Delete</button>
            </div>
        <% } %>
    </div>
</div>
