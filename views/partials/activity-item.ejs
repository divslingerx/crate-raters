<div class="bg-gray-900 border border-gray-800 rounded-lg p-4">
    <div class="flex items-start gap-3">
        <div class="w-8 h-8 rounded-full bg-gray-800 flex items-center justify-center text-gray-500 flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0" />
            </svg>
        </div>
        <div class="flex-1 min-w-0">
            <p class="text-gray-300">
                <a href="/users/<%= activity.user.id %>" class="font-semibold text-white hover:text-indigo-400"><%= activity.user.name %></a>

                <% if (activity.type === 'added_release' && activity.release) { %>
                    added <a href="/releases/<%= activity.release.id %>" class="text-indigo-400 hover:text-indigo-300 font-medium"><%= activity.release.album %></a> by <%= activity.release.artist %> to their collection
                <% } else if (activity.type === 'commented' && activity.release) { %>
                    commented on <a href="/releases/<%= activity.release.id %>" class="text-indigo-400 hover:text-indigo-300 font-medium"><%= activity.release.album %></a> by <%= activity.release.artist %>
                <% } else if (activity.type === 'liked' && activity.release) { %>
                    liked <a href="/releases/<%= activity.release.id %>" class="text-indigo-400 hover:text-indigo-300 font-medium"><%= activity.release.album %></a> by <%= activity.release.artist %>
                <% } else if (activity.type === 'followed' && activity.targetUser) { %>
                    started following <a href="/users/<%= activity.targetUser.id %>" class="text-indigo-400 hover:text-indigo-300 font-medium"><%= activity.targetUser.name %></a>
                <% } else if (activity.type === 'posted') { %>
                    <% if (activity.text) { %>
                        <span class="text-gray-300"><%= activity.text %></span>
                    <% } %>
                <% } %>
            </p>

            <% if (activity.type === 'posted' && activity.imageUrl) { %>
                <div class="mt-3">
                    <img src="<%= resolveImage(activity.imageUrl) %>" alt="Post image" class="rounded-lg max-h-80 object-cover">
                </div>
            <% } %>

            <p class="text-xs text-gray-600 mt-1">
                <%= activity.createdAt ? new Date(activity.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : '' %>
            </p>
        </div>
    </div>
</div>
