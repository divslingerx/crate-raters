<a href="/records/<%= record.id %>" class="bg-gray-900 border border-gray-800 rounded-lg overflow-hidden hover:border-gray-600 transition-colors">
    <% if (record.image) { %>
        <img src="<%= record.image %>" alt="<%= record.album %>" class="w-full aspect-square object-cover">
    <% } else { %>
        <div class="w-full aspect-square bg-gray-800 flex items-center justify-center text-gray-500">No Image</div>
    <% } %>
    <div class="p-4">
        <h2 class="font-semibold text-white truncate"><%= record.album %></h2>
        <p class="text-gray-400 text-sm"><%= record.artist %></p>
        <% if (record.year) { %>
            <p class="text-gray-500 text-xs mt-1"><%= record.year %></p>
        <% } %>
    </div>
</a>
