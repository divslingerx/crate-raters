<button
    hx-post="/users/<%= targetUser.id %>/follow"
    hx-swap="outerHTML"
    class="px-4 py-1.5 rounded-lg text-sm font-medium transition-colors
        <%= isFollowing ? 'bg-gray-700 text-gray-300 border border-gray-600 hover:bg-red-900/30 hover:text-red-400 hover:border-red-600/50' : 'bg-indigo-600 hover:bg-indigo-500 text-white' %>"
>
    <%= isFollowing ? 'Following' : 'Follow' %>
</button>
