<div class="flex gap-4 overflow-x-auto pb-2">
    <% suggestedUsers.forEach(function(u) { %>
        <a href="/users/<%= u.id %>" class="bg-gray-900 border border-gray-800 rounded-lg p-4 hover:border-gray-600 transition-colors flex items-center gap-3 flex-shrink-0 min-w-[200px]">
            <div class="w-10 h-10 rounded-full bg-gray-800 flex items-center justify-center text-gray-500 overflow-hidden flex-shrink-0">
                <% if (u.profile && u.profile.avatarUrl) { %>
                    <img src="<%= resolveImage(u.profile.avatarUrl) %>" alt="<%= u.name %>" class="w-full h-full object-cover">
                <% } else { %>
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0" />
                    </svg>
                <% } %>
            </div>
            <div>
                <p class="font-medium text-white text-sm"><%= u.name %></p>
            </div>
        </a>
    <% }); %>
</div>
