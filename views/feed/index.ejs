<div class="max-w-2xl mx-auto">
    <h1 class="text-3xl font-bold mb-6">Feed</h1>

    <%- include('../partials/post-form') %>

    <div class="space-y-4 mt-6">
        <% if (activities.length === 0) { %>
            <p class="text-gray-500">No activity yet. Follow some users to see their activity here.</p>
        <% } else { %>
            <% activities.forEach(function(activity) { %>
                <%- include('../partials/activity-item', { activity }) %>
            <% }); %>
        <% } %>
    </div>
</div>
