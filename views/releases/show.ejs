<div class="max-w-4xl mx-auto">
    <div class="bg-gray-900 border border-gray-800 rounded-lg overflow-hidden">
        <div class="md:flex">
            <% if (release.image) { %>
                <div class="md:w-1/2">
                    <img src="<%= resolveImage(release.image) %>" alt="<%= release.album %>" class="w-full aspect-square object-cover">
                </div>
            <% } %>
            <div class="p-6 md:w-1/2 flex flex-col justify-between">
                <div>
                    <h1 class="text-3xl font-bold text-white mb-2"><%= release.album %></h1>
                    <p class="text-xl text-gray-300 mb-4"><%= release.artist %></p>
                    <% if (release.year) { %>
                        <p class="text-gray-400 mb-2"><span class="font-medium text-gray-300">Year:</span> <%= release.year %></p>
                    <% } %>
                    <% if (release.found) { %>
                        <p class="text-gray-400 mb-2"><span class="font-medium text-gray-300">Found:</span> <%= release.found %></p>
                    <% } %>

                    <!-- Tags -->
                    <% if (release.releaseTags && release.releaseTags.length > 0) { %>
                        <div class="flex flex-wrap gap-1.5 mb-4">
                            <% release.releaseTags.forEach(function(rt) { %>
                                <span class="text-xs px-2 py-0.5 rounded-full bg-gray-800 text-gray-300 border border-gray-700"><%= rt.tag.name %></span>
                            <% }); %>
                        </div>
                    <% } %>

                    <!-- Format & Pressing Details -->
                    <div class="mt-4 space-y-1">
                        <% if (release.format) { %>
                            <p class="text-gray-400">
                                <span class="font-medium text-gray-300">Format:</span>
                                <span class="inline-block text-xs px-2 py-0.5 rounded-full ml-1
                                    <%= release.format === 'vinyl' ? 'bg-amber-900/50 text-amber-400' : '' %>
                                    <%= release.format === 'cd' ? 'bg-blue-900/50 text-blue-400' : '' %>
                                    <%= release.format === 'cassette' ? 'bg-purple-900/50 text-purple-400' : '' %>
                                "><%= release.format === 'cd' ? 'CD' : release.format.charAt(0).toUpperCase() + release.format.slice(1) %></span>
                                <% if (release.vinylSize) { %>
                                    <span class="text-gray-500 ml-1">(<%= release.vinylSize %>)</span>
                                <% } %>
                            </p>
                        <% } %>
                        <% if (release.color) { %>
                            <p class="text-gray-400"><span class="font-medium text-gray-300">Color:</span> <%= release.color %></p>
                        <% } %>
                        <% if (release.label) { %>
                            <p class="text-gray-400"><span class="font-medium text-gray-300">Label:</span> <%= release.label %></p>
                        <% } %>
                        <% if (release.catalogNumber) { %>
                            <p class="text-gray-400"><span class="font-medium text-gray-300">Cat #:</span> <%= release.catalogNumber %></p>
                        <% } %>
                        <% if (release.country) { %>
                            <p class="text-gray-400"><span class="font-medium text-gray-300">Country:</span> <%= release.country %></p>
                        <% } %>
                        <% if (release.edition) { %>
                            <p class="text-gray-400"><span class="font-medium text-gray-300">Edition:</span> <%= release.edition %></p>
                        <% } %>
                        <% if (release.barcode) { %>
                            <p class="text-gray-400"><span class="font-medium text-gray-300">Barcode:</span> <%= release.barcode %></p>
                        <% } %>
                        <% if (release.matrix) { %>
                            <p class="text-gray-400"><span class="font-medium text-gray-300">Matrix:</span> <%= release.matrix %></p>
                        <% } %>
                        <% if (release.tapeType) { %>
                            <p class="text-gray-400"><span class="font-medium text-gray-300">Tape Type:</span> <%= release.tapeType %></p>
                        <% } %>
                    </div>
                </div>

                <div class="flex gap-3 mt-4 flex-wrap">
                    <% if (user) { %>
                        <%- include('../partials/like-button', { release, user }) %>
                        <%- include('../partials/want-button', { release, user }) %>
                    <% } %>
                </div>

                <% if (user && user.id === release.userId) { %>
                    <div class="flex gap-3 mt-4">
                        <a href="/releases/<%= release.id %>/edit" class="bg-yellow-600 hover:bg-yellow-500 text-white px-4 py-2 rounded-lg font-medium transition-colors">Edit</a>
                        <button
                            hx-delete="/releases/<%= release.id %>"
                            hx-confirm="Are you sure?"
                            hx-swap="none"
                            class="bg-red-600 hover:bg-red-500 text-white px-4 py-2 rounded-lg font-medium transition-colors"
                        >Delete</button>
                        <form action="/releases/<%= release.id %>?_method=DELETE" method="POST" class="inline hidden" id="delete-fallback">
                            <button type="submit" class="bg-red-600 hover:bg-red-500 text-white px-4 py-2 rounded-lg font-medium transition-colors">Delete</button>
                        </form>
                    </div>
                <% } %>
            </div>
        </div>
    </div>

    <!-- Comments Section -->
    <div class="mt-8">
        <div class="flex items-center justify-between mb-4">
            <h2 class="text-2xl font-bold text-white">Comments</h2>
        </div>
        <% if (user) { %>
            <form
                hx-post="/releases/<%= release.id %>/comments"
                hx-target="#comments-list"
                hx-swap="afterbegin"
                hx-on::after-request="if(event.detail.successful) this.reset()"
                action="/releases/<%= release.id %>/comments"
                method="POST"
                class="mb-6"
            >
                <div class="flex gap-3">
                    <input type="text" name="text" placeholder="Add a comment..." required
                        class="flex-1 bg-gray-800 border border-gray-700 rounded-lg px-4 py-2 text-gray-100 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent">
                    <button type="submit" class="bg-indigo-600 hover:bg-indigo-500 text-white px-4 py-2 rounded-lg font-medium transition-colors text-sm">Add Comment</button>
                </div>
            </form>
        <% } %>
        <div id="comments-list" class="space-y-4">
            <% if (release.comments && release.comments.length > 0) { %>
                <% release.comments.forEach(function(comment) { %>
                    <%- include('../partials/comment', { comment, releaseId: release.id, user }) %>
                <% }); %>
            <% } %>
        </div>
        <% if (!release.comments || release.comments.length === 0) { %>
            <p class="text-gray-500 no-comments">No comments yet.</p>
        <% } %>
    </div>

    <div class="mt-6">
        <a href="/releases" class="text-indigo-400 hover:text-indigo-300">Back to Releases</a>
    </div>
</div>
