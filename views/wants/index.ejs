<div class="mb-8">
    <h1 class="text-3xl font-bold">My Wishlist</h1>
    <p class="text-gray-400 mt-1">Releases you want to find</p>
</div>

<% if (releases.length === 0) { %>
    <p class="text-gray-500">You haven't added any releases to your wishlist yet.</p>
<% } else { %>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        <% releases.forEach(function(release) { %>
            <%- include('../partials/release-card', { release }) %>
        <% }); %>
    </div>
<% } %>
